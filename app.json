{
  "expo": {
    "name": "Lifestream",
    "slug": "lifestream",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#2563EB"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.lifestream.app",
      "infoPlist": {
        "NSCalendarsUsageDescription": "Lifestream needs calendar access to schedule reminders."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#2563EB"
      },
      "package": "com.lifestream.app"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#2563EB",
          "sounds": [],
          "androidMode": "default",
          "androidCollapsedTitle": "Lifestream"
        }
      ],
      "expo-secure-store"
    ],
    "scheme": "lifestream",
    "experiments": {
      "typedRoutes": true
    }
  }
}
