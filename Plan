Cloud Functions (Event-Driven Triggers)

// functions/src/index.ts

// 1. NLP Parser — triggers when new reminder is created with rawInput
export const parseReminderInput = onDocumentCreated(
  'users/{userId}/reminders/{reminderId}',
  async (event) => {
    const data = event.data?.data();
    if (!data?.rawInput || data.parsedByAI) return;
    
    // Call Vertex AI (Gemini) to extract dates and context
    const parsed = await parseWithVertexAI(data.rawInput);
    
    await event.data?.ref.update({
      expirationDate: Timestamp.fromDate(parsed.date),
      category: parsed.category,
      reminderIntervals: generateIntervals(parsed.urgencyLevel),
      parsedByAI: true,
      nextNotificationAt: calculateNextNotification(parsed.date, parsed.intervals)
    });
  }
);

// 2. Notification Scheduler — runs every hour via Cloud Scheduler
export const scheduleNotifications = onSchedule('every 60 minutes', async () => {
  const now = Timestamp.now();
  const cutoff = Timestamp.fromMillis(now.toMillis() + 3600000); // +1 hour
  
  const dueReminders = await db
    .collectionGroup('reminders')
    .where('status', '==', 'active')
    .where('nextNotificationAt', '<=', cutoff)
    .get();
  
  // Push to Redis queue for ordered dispatch
  const pipeline = redis.pipeline();
  dueReminders.docs.forEach(doc => {
    pipeline.zadd('notification_queue', doc.data().nextNotificationAt.toMillis(), doc.id);
  });
  await pipeline.exec();
});

// 3. Audit Logger — triggers on any reminder write
export const logReminderChange = onDocumentWritten(
  'users/{userId}/reminders/{reminderId}',
  async (event) => {
    const before = event.data?.before?.data();
    const after = event.data?.after?.data();
    
    const changedFields = diffObjects(before, after);
    
    await db.collection('auditLogs').add({
      userId: event.params.userId,
      reminderId: event.params.reminderId,
      action: determineAction(before, after),
      changedFields,
      actorId: after?.lastModifiedBy || 'system',
      timestamp: Timestamp.now()
    });
  }
);


Cloud Run — NestJS API (Microservice Layer)

// src/notifications/notification.service.ts (NestJS)

@Injectable()
export class NotificationService {
  constructor(
    private readonly fcm: FirebaseMessagingService,
    private readonly redis: RedisService,
    private readonly firestore: FirestoreService
  ) {}

  async dispatchNotification(reminderId: string): Promise<void> {
    const reminder = await this.firestore.getReminder(reminderId);
    const user = await this.firestore.getUser(reminder.userId);
    
    // Check quiet hours
    if (this.isQuietHours(user.settings)) {
      await this.deferToEndOfQuietHours(reminderId, user.settings);
      return;
    }
    
    // Build escalating message based on snooze count
    const message = this.buildEscalatingMessage(reminder);
    
    // Send to all user devices
    const results = await this.fcm.sendMulticast({
      tokens: user.fcmTokens,
      notification: {
        title: message.title,
        body: message.body,
      },
      data: {
        reminderId: reminder.id,
        action: 'open_reminder',
        urgencyLevel: message.urgencyLevel,
        daysUntilExpiry: String(message.daysUntilExpiry)
      },
      apns: {
        payload: {
          aps: {
            'interruption-level': message.urgencyLevel === 'critical' ? 'time-sensitive' : 'active',
            sound: 'default'
          }
        }
      },
      android: {
        priority: message.urgencyLevel === 'critical' ? 'high' : 'normal',
        notification: { channelId: `lifestream_${message.urgencyLevel}` }
      }
    });
    
    // Update Firestore with next scheduled notification
    await this.firestore.updateReminderAfterNotification(reminder, results);
  }

  private buildEscalatingMessage(reminder: Reminder): NotificationMessage {
    const days = daysBetween(new Date(), reminder.expirationDate.toDate());
    
    if (days <= 1) return {
      title: '🚨 URGENT: Expires Tomorrow!',
      body: `${reminder.title} expires in less than 24 hours. Act now.`,
      urgencyLevel: 'critical'
    };
    if (days <= 7) return {
      title: `⚠️ ${reminder.title} — ${days} days left`,
      body: 'This is getting urgent. Tap to review.',
      urgencyLevel: 'high'
    };
    return {
      title: `📅 Reminder: ${reminder.title}`,
      body: `Expires in ${days} days.`,
      urgencyLevel: 'normal'
    };
  }
}


