// database/sync.ts — WatermelonDB ↔ Firestore bridge

export class LifestreamSyncAdapter {
  async synchronize() {
    await synchronize({
      database,
      pullChanges: async ({ lastPulledAt }) => {
        const snapshot = await db
          .collection(`users/${userId}/reminders`)
          .where('updatedAt', '>', Timestamp.fromMillis(lastPulledAt ?? 0))
          .get();
        
        return {
          changes: formatForWatermelonDB(snapshot.docs),
          timestamp: Date.now()
        };
      },
      pushChanges: async ({ changes }) => {
        const batch = db.batch();
        changes.reminders.created.forEach(r => {
          batch.set(db.doc(`users/${userId}/reminders/${r.id}`), toFirestore(r));
        });
        changes.reminders.updated.forEach(r => {
          batch.update(db.doc(`users/${userId}/reminders/${r.id}`), toFirestore(r));
        });
        await batch.commit();
      }
    });
  }
}


